<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>全息粒子 3D 模型 - 手势交互</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
            background-color: #030305;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            touch-action: none; /* 防止移动端意外滑动 */
        }

        #canvas-container {
            width: 100vw;
            height: 100vh;
        }

        #ui-overlay {
            position: absolute;
            top: 20px;
            left: 20px;
            z-index: 10;
            color: #fff;
            pointer-events: none;
            text-shadow: 0 2px 4px rgba(0,0,0,0.8);
        }

        .status-card {
            background: rgba(15, 15, 20, 0.7);
            backdrop-filter: blur(12px);
            padding: 20px;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            margin-bottom: 10px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
            pointer-events: auto; /* 让卡片内的内容可以点击（如果需要） */
        }

        .status-item {
            margin: 8px 0;
            font-size: 14px;
            display: flex;
            justify-content: space-between;
            width: 200px;
        }
        
        .status-value {
            color: #ffaa00;
            font-weight: bold;
        }

        #video-container {
            position: absolute;
            bottom: 20px;
            right: 20px;
            width: 160px; /* 为移动端适当缩小 */
            height: 120px;
            border-radius: 12px;
            overflow: hidden;
            border: 2px solid rgba(255, 170, 0, 0.5);
            transform: scaleX(-1);
            background: #111;
            box-shadow: 0 4px 15px rgba(255, 170, 0, 0.2);
            z-index: 10;
        }

        #webcam-video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .loader {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #ffaa00;
            text-align: center;
            z-index: 100;
            background: rgba(0,0,0,0.8);
            padding: 30px;
            border-radius: 20px;
            backdrop-filter: blur(5px);
        }

        .loader-spinner {
            border: 4px solid rgba(255, 170, 0, 0.1);
            border-left-color: #ffaa00;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            animation: spin 1s linear infinite;
            margin: 0 auto 15px;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* 右上角按钮组 */
        .action-group {
            position: absolute;
            top: 20px;
            right: 20px;
            z-index: 20;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        
        .btn {
            background: rgba(15, 15, 20, 0.7);
            color: white;
            border: 1px solid rgba(255, 170, 0, 0.5);
            padding: 10px 18px;
            border-radius: 50px;
            font-size: 14px;
            cursor: pointer;
            backdrop-filter: blur(10px);
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .btn.primary {
            background: linear-gradient(135deg, #ff8800, #ffaa00);
            border: none;
            box-shadow: 0 4px 15px rgba(255, 170, 0, 0.4);
        }

        .btn:hover {
            transform: scale(1.05);
        }

        #imageUpload { display: none; }

        /* 二维码弹窗样式 */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(8px);
            z-index: 999;
            justify-content: center;
            align-items: center;
            flex-direction: column;
        }

        .qr-card {
            background: white;
            padding: 30px;
            border-radius: 20px;
            text-align: center;
            color: #333;
            max-width: 90vw;
        }

        #qrcode {
            margin: 20px auto;
            display: flex;
            justify-content: center;
        }

        .warning-text {
            color: #d93025;
            font-size: 12px;
            margin-top: 15px;
            max-width: 250px;
            line-height: 1.5;
            display: none;
            background: #fce8e6;
            padding: 10px;
            border-radius: 8px;
        }

        .close-btn {
            margin-top: 20px;
            padding: 8px 24px;
            background: #eee;
            border: none;
            border-radius: 20px;
            cursor: pointer;
            font-weight: bold;
        }

        /* 移动端适配 */
        @media (max-width: 768px) {
            #ui-overlay { transform: scale(0.8); transform-origin: top left; }
            .action-group { flex-direction: row; top: auto; bottom: 150px; right: 20px; }
            .btn { padding: 8px 12px; font-size: 12px; }
        }
    </style>
</head>
<body>

    <div id="loader" class="loader">
        <div class="loader-spinner"></div>
        <p id="loader-text">正在初始化场景与摄像头...</p>
    </div>

    <!-- 二维码弹窗 -->
    <div class="modal-overlay" id="qrModal">
        <div class="qr-card">
            <h3 style="margin: 0 0 10px 0;">📱 手机扫码体验</h3>
            <p style="font-size: 14px; color: #666; margin: 0;">保持手机与电脑在同一局域网</p>
            <div id="qrcode"></div>
            <div id="qrWarning" class="warning-text">
                ⚠️ 检测到非 HTTPS 环境。<br>移动端浏览器禁止在 HTTP 下调用摄像头。请使用 <b>ngrok</b> 等内网穿透工具提供 https 链接。
            </div>
            <button class="close-btn" onclick="document.getElementById('qrModal').style.display='none'">关闭</button>
        </div>
    </div>

    <!-- 操作按钮区 -->
    <div class="action-group">
        <button class="btn" onclick="showQRModal()">📱 手机扫码</button>
        <button class="btn primary" onclick="document.getElementById('imageUpload').click()">
            📷 上传照片
        </button>
        <input type="file" id="imageUpload" accept="image/png, image/jpeg, image/jpg">
    </div>

    <div id="ui-overlay">
        <div class="status-card">
            <h2 style="margin: 0 0 15px 0; color: #ffaa00; font-size: 18px;">全息模型控制器</h2>
            <div class="status-item"><span>手势状态:</span> <span class="status-value" id="gesture-type">等待中...</span></div>
            <div class="status-item"><span>相机距离:</span> <span class="status-value" id="zoom-speed">0</span></div>
            <div class="status-item"><span>模型旋转:</span> <span class="status-value" id="rotation-val">0°</span></div>
        </div>
        <div class="status-card" style="font-size: 12px; opacity: 0.8; width: 200px; color: #ccc;">
            <strong>操作指南:</strong><br><br>
            ✋ <strong>旋转手掌:</strong> 360° 环绕观察模型<br>
            ✊ <strong>握拳退后:</strong> 相机快速远离主体<br>
            🖐️ <strong>张手靠近:</strong> 相机快速推近主体
        </div>
    </div>

    <div id="video-container">
        <video id="webcam-video" autoplay playsinline></video>
    </div>

    <div id="canvas-container"></div>

    <!-- 引入必要的库 -->
    <script src="https://cdn.jsdelivr.net/npm/@mediapipe/hands/hands.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js"></script>
    <!-- 引入 qrcode.js 用于生成二维码 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

    <script type="importmap">
        {
            "imports": {
                "three": "https://cdnjs.cloudflare.com/ajax/libs/three.js/0.160.0/three.module.min.js"
            }
        }
    </script>

    <script type="module">
        import * as THREE from 'three';

        // 为了兼顾移动端性能，适度降低粒子总数
        const isMobile = window.innerWidth < 768;
        const MODEL_PARTICLES = isMobile ? 60000 : 120000; 
        const RING_PARTICLES = isMobile ? 2500 : 5000;    
        const MIN_CAMERA_DIST = 20;
        const MAX_CAMERA_DIST = 120;
        
        const DEFAULT_IMAGE_URL = 'https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80';
        
        let scene, camera, renderer;
        let mainGroup, modelParticles, ring1, ring2;
        let videoElement, hands;
        let currentDistance = 60;
        let targetRotation = 0;
        let currentRotation = 0;

        // 暴露给全局以便普通按钮调用
        window.showQRModal = function() {
            const modal = document.getElementById('qrModal');
            const qrContainer = document.getElementById('qrcode');
            const warning = document.getElementById('qrWarning');
            
            // 清空旧二维码
            qrContainer.innerHTML = '';
            
            // 获取当前网址。如果在本地 VSCode，可能是 http://192.168.x.x:5500/index.html
            const currentUrl = window.location.href;
            
            new QRCode(qrContainer, {
                text: currentUrl,
                width: 180,
                height: 180,
                colorDark : "#000000",
                colorLight : "#ffffff",
                correctLevel : QRCode.CorrectLevel.H
            });

            // 检查 HTTPS 权限问题
            if (currentUrl.startsWith('http://') && !currentUrl.includes('localhost') && !currentUrl.includes('127.0.0.1')) {
                warning.style.display = 'block';
            } else {
                warning.style.display = 'none';
            }

            modal.style.display = 'flex';
        };

        async function init() {
            scene = new THREE.Scene();
            scene.fog = new THREE.FogExp2(0x030305, 0.005);
            
            camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
            
            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2)); // 限制像素比优化移动端性能
            document.getElementById('canvas-container').appendChild(renderer.domElement);

            mainGroup = new THREE.Group();
            scene.add(mainGroup);

            await build3DModelFromImage(DEFAULT_IMAGE_URL);
            createRings();
            createBackgroundStars();

            setupMediaPipe();
            setupImageUpload();
            
            animate();
        }

        async function build3DModelFromImage(imageUrl) {
            return new Promise((resolve) => {
                const loader = new THREE.ImageLoader();
                loader.setCrossOrigin('anonymous');
                
                loader.load(imageUrl, (image) => {
                    if (modelParticles) {
                        mainGroup.remove(modelParticles);
                        modelParticles.geometry.dispose();
                        modelParticles.material.dispose();
                    }

                    const canvas = document.createElement('canvas');
                    const ctx = canvas.getContext('2d', { willReadFrequently: true });
                    
                    const aspect = image.width / image.height;
                    let imgW = 256;
                    let imgH = 256;
                    if (aspect > 1) {
                        imgH = Math.floor(256 / aspect);
                    } else {
                        imgW = Math.floor(256 * aspect);
                    }

                    canvas.width = imgW;
                    canvas.height = imgH;
                    ctx.drawImage(image, 0, 0, imgW, imgH);
                    const imgData = ctx.getImageData(0, 0, imgW, imgH).data;

                    const positions = [];
                    const colors = [];
                    const scale = 0.15;

                    for (let i = 0; i < MODEL_PARTICLES; i++) {
                        const x = Math.floor(Math.random() * imgW);
                        const y = Math.floor(Math.random() * imgH);
                        const pixelIdx = (y * imgW + x) * 4;

                        const r = imgData[pixelIdx] / 255;
                        const g = imgData[pixelIdx + 1] / 255;
                        const b = imgData[pixelIdx + 2] / 255;
                        const a = imgData[pixelIdx + 3] / 255;

                        if (r > 0.9 && g > 0.9 && b > 0.9) continue;
                        if (a < 0.1) continue;

                        const px = (x - imgW / 2) * scale + (Math.random() - 0.5) * 0.15;
                        const py = (imgH / 2 - y) * scale + (Math.random() - 0.5) * 0.15;
                        
                        const luminance = 0.299 * r + 0.587 * g + 0.114 * b;
                        const depthThickness = 8;
                        const pz = (luminance * depthThickness) - (depthThickness / 2) + (Math.random() - 0.5) * 1.5;

                        positions.push(px, py, pz);
                        colors.push(r * 1.5, g * 1.5, b * 1.5);
                    }

                    const geometry = new THREE.BufferGeometry();
                    geometry.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
                    geometry.setAttribute('color', new THREE.Float32BufferAttribute(colors, 3));

                    const material = new THREE.PointsMaterial({
                        size: isMobile ? 0.2 : 0.12, // 移动端稍微增大粒子尺寸以弥补数量减少
                        vertexColors: true,
                        transparent: true,
                        opacity: 0.85,
                        blending: THREE.AdditiveBlending,
                        depthWrite: false
                    });

                    modelParticles = new THREE.Points(geometry, material);
                    mainGroup.add(modelParticles);
                    resolve();
                });
            });
        }

        function setupImageUpload() {
            const uploadInput = document.getElementById('imageUpload');
            uploadInput.addEventListener('change', (e) => {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = async (event) => {
                        const imageUrl = event.target.result;
                        const loaderEl = document.getElementById('loader');
                        document.getElementById('loader-text').innerText = "正在构建 3D 全息模型...";
                        loaderEl.style.display = 'block';
                        
                        await build3DModelFromImage(imageUrl);
                        loaderEl.style.display = 'none';
                    };
                    reader.readAsDataURL(file);
                }
            });
        }

        function createRings() {
            function createRingObj(innerR, outerR, count, colorHex) {
                const geo = new THREE.BufferGeometry();
                const pos = [];
                for (let i = 0; i < count; i++) {
                    const angle = Math.random() * Math.PI * 2;
                    const r = innerR + Math.random() * (outerR - innerR);
                    const x = Math.cos(angle) * r;
                    const z = Math.sin(angle) * r;
                    const y = (Math.random() - 0.5) * 1.5;
                    pos.push(x, y, z);
                }
                geo.setAttribute('position', new THREE.Float32BufferAttribute(pos, 3));
                const mat = new THREE.PointsMaterial({
                    size: 0.1, color: colorHex, transparent: true, opacity: 0.4, blending: THREE.AdditiveBlending
                });
                return new THREE.Points(geo, mat);
            }

            ring1 = createRingObj(22, 28, RING_PARTICLES, 0xffccaa);
            ring2 = createRingObj(30, 36, RING_PARTICLES / 2, 0x88bbff); 
            ring1.rotation.x = Math.PI / 2.5;
            ring2.rotation.x = -Math.PI / 3;

            mainGroup.add(ring1);
            mainGroup.add(ring2);
        }

        function createBackgroundStars() {
            const geo = new THREE.BufferGeometry();
            const pos = [];
            for(let i=0; i<2000; i++) pos.push((Math.random()-0.5)*400, (Math.random()-0.5)*400, (Math.random()-0.5)*400);
            geo.setAttribute('position', new THREE.Float32BufferAttribute(pos, 3));
            const mat = new THREE.PointsMaterial({ size: 0.2, color: 0x555566 });
            scene.add(new THREE.Points(geo, mat));
        }

        function setupMediaPipe() {
            videoElement = document.getElementById('webcam-video');
            const gestureTypeEl = document.getElementById('gesture-type');
            const zoomSpeedEl = document.getElementById('zoom-speed');
            const rotationValEl = document.getElementById('rotation-val');

            hands = new Hands({
                locateFile: (file) => `https://cdn.jsdelivr.net/npm/@mediapipe/hands/${file}`
            });

            hands.setOptions({
                maxNumHands: 1,
                modelComplexity: 1,
                minDetectionConfidence: 0.5,
                minTrackingConfidence: 0.5
            });

            hands.onResults((results) => {
                if (results.multiHandLandmarks && results.multiHandLandmarks.length > 0) {
                    const landmarks = results.multiHandLandmarks[0];
                    const isFist = checkIsFist(landmarks);
                    
                    const angle = Math.atan2(landmarks[9].y - landmarks[0].y, landmarks[9].x - landmarks[0].x) + Math.PI / 2;
                    targetRotation = angle;

                    if (isFist) {
                        gestureTypeEl.innerText = "✊ 握拳 (远离中)";
                        gestureTypeEl.style.color = "#ff4444";
                        currentDistance += Math.pow(currentDistance * 0.05, 1.5) * 0.1;
                    } else {
                        gestureTypeEl.innerText = "🖐️ 张开 (靠近中)";
                        gestureTypeEl.style.color = "#44ff44";
                        const approachSpeed = (currentDistance - MIN_CAMERA_DIST) * 0.08;
                        currentDistance -= approachSpeed;
                    }

                    currentDistance = Math.max(MIN_CAMERA_DIST, Math.min(MAX_CAMERA_DIST, currentDistance));
                    
                    zoomSpeedEl.innerText = currentDistance.toFixed(1) + " M";
                    rotationValEl.innerText = Math.round(targetRotation * 180 / Math.PI) + "°";
                } else {
                    gestureTypeEl.innerText = "未检测到手部";
                    gestureTypeEl.style.color = "#ffaa00";
                }
            });

            const cameraPipe = new Camera(videoElement, {
                onFrame: async () => {
                    await hands.send({ image: videoElement });
                },
                width: 640,
                height: 480
            });
            cameraPipe.start().catch(err => {
                console.error("Camera start failed:", err);
                document.getElementById('loader-text').innerText = "获取摄像头权限失败\n请确保处于 HTTPS 或 localhost 环境。";
            });
            
            document.getElementById('loader').style.display = 'none';
        }

        function checkIsFist(landmarks) {
            const fingers = [8, 12, 16, 20];
            let closedFingers = 0;
            for (const f of fingers) {
                if (landmarks[f].y > landmarks[f - 2].y) closedFingers++;
            }
            return closedFingers >= 3;
        }

        function animate() {
            requestAnimationFrame(animate);

            if (mainGroup) mainGroup.rotation.y += 0.0005; 
            if (ring1 && ring2) {
                ring1.rotation.z += 0.002;
                ring2.rotation.z -= 0.0015;
            }

            currentRotation += (targetRotation - currentRotation) * 0.1;
            camera.position.x = Math.sin(currentRotation) * currentDistance;
            camera.position.z = Math.cos(currentRotation) * currentDistance;
            camera.position.y = currentDistance * 0.1; 
            camera.lookAt(0, 0, 0);

            renderer.render(scene, camera);
        }

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        window.onload = init;
    </script>
</body>
</html>
